# =============================================================
# Supabase — Required (Phase 2)
# =============================================================
# PUBLIC: Safe for browser. Find in Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SECRET: Server-side only. Never expose to the browser.
# Find in Supabase → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# Stripe — Phase 10 (uncomment when needed)
# =============================================================
# SECRET: Server-side only.
# STRIPE_SECRET_KEY=your-stripe-secret-key
# PUBLIC: Safe for browser.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# =============================================================
# Resend — Phase 10 (uncomment when needed)
# =============================================================
# SECRET: Server-side only.
# RESEND_API_KEY=your-resend-api-key
